# Copy to .env (or let scripts/docker-build.ps1 generate it).
# Image tags consumed by the compose files.
CONFIGSERVER_VERSION=1.0.0-SNAPSHOT
EUREKASERVER_VERSION=0.0.1-SNAPSHOT
ORDER_SERVICE_VERSION=1.0.0-SNAPSHOT
GATEWAYSERVER_VERSION=0.0.1-SNAPSHOT

# Database credentials consumed by docker-compose.db.yml / docker-compose.yml.
# DB_USERNAME=root
# DB_PASSWORD=secret

# Config server Git backend credentials (diningplate-config repo).
# Leave blank while the repo is public.
# Use a GitHub username + Personal Access Token (PAT) as the password when it goes private.
# CONFIG_GIT_USERNAME=gh_username
# CONFIG_GIT_PASSWORD=ghp_your_personal_access_token
